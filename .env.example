# Ejemplo de archivo .env.local para NoDox
# Copiar este archivo a .env.local y rellenar con tus valores
# NUNCA comprometer .env.local en el repositorio

# Clave de cifrado Fernet (OBLIGATORIO)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NODOX_KEY=aqui_tu_clave_generada

# Nivel de logging (opcional)
# LOG_LEVEL=INFO

# Ruta de base de datos (opcional)
# DB_PATH=./logs/nodox.db
